{
  "name": "veronum-desktop",
  "productName": "Veronum",
  "version": "0.1.2",
  "description": "Veronum as a native desktop app — same UI as thetoolswebsite.com, plus zero-popup live disk access.",
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "build:web": "node scripts/build-web.cjs",
    "dev": "electron-vite dev --watch",
    "dev:bundled": "node scripts/build-web.cjs && electron-vite dev --watch",
    "build": "node scripts/build-web.cjs && electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json",
    "dist:mac": "electron-vite build && electron-builder --mac",
    "dist:mac:dev": "electron-vite build && electron-builder --mac --publish never",
    "release:mac": "electron-vite build && electron-builder --mac --publish always",
    "dist:win": "electron-vite build && electron-builder --win --publish always",
    "postinstall": "electron-builder install-app-deps"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@types/node": "^22.9.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
